generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")   // pgbouncer pooler (6543) for runtime queries
  directUrl = env("DIRECT_URL")     // direct connection (5432) for migrations
}

model Client {
  id          String   @id @default(uuid())
  name        String
  clerkUserId String   @unique @map("clerk_user_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  debtors    Debtor[]
  xeroConnection XeroConnection?

  @@map("clients")
}

model Debtor {
  id                String              @id @default(uuid())
  clientId          String              @map("client_id")
  xeroContactId     String              @map("xero_contact_id")
  name              String
  email             String?
  scoreValue        Int?                @map("score_value")
  scoreBand         String?             @map("score_band")
  recommendedAction String?             @map("recommended_action")
  scoreRationale    String?             @map("score_rationale")
  scoredAt          DateTime?           @map("scored_at")
  client            Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  invoices          Invoice[]
  interactions      DebtorInteraction[]
  drafts            OutreachDraft[]
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  @@unique([clientId, xeroContactId])
  @@index([clientId])
  @@map("debtors")
}

model DebtorInteraction {
  id        String   @id @default(uuid())
  clientId  String   @map("client_id")
  debtorId  String   @map("debtor_id")
  type      String
  summary   String
  debtor    Debtor   @relation(fields: [debtorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([clientId])
  @@index([debtorId])
  @@map("debtor_interactions")
}

model OutreachDraft {
  id                String    @id @default(uuid())
  clientId          String    @map("client_id")
  debtorId          String    @map("debtor_id")
  channel           String    @default("email")
  subject           String
  body              String    @db.Text
  status            String    @default("pending")
  toEmailIntended   String?   @map("to_email_intended")
  toEmailActual     String?   @map("to_email_actual")
  scoreValueAtDraft Int?      @map("score_value_at_draft")
  error             String?
  sentAt            DateTime? @map("sent_at")
  debtor            Debtor    @relation(fields: [debtorId], references: [id], onDelete: Cascade)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@index([clientId])
  @@index([status])
  @@index([debtorId])
  @@map("outreach_drafts")
}

model Invoice {
  id             String   @id @default(uuid())
  clientId       String   @map("client_id")
  debtorId       String   @map("debtor_id")
  xeroInvoiceId  String   @map("xero_invoice_id")
  invoiceNumber  String   @map("invoice_number")
  issueDate      DateTime @map("issue_date")
  dueDate        DateTime @map("due_date")
  totalCents     Int      @map("total_cents")
  amountDueCents Int      @map("amount_due_cents")
  amountPaidCents Int     @map("amount_paid_cents")
  status         String
  currencyCode   String   @map("currency_code")
  debtor         Debtor   @relation(fields: [debtorId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([clientId, xeroInvoiceId])
  @@index([clientId])
  @@index([debtorId])
  @@map("invoices")
}

model XeroConnection {
  id              String   @id @default(uuid())
  clientId        String   @unique @map("client_id")
  xeroTenantId    String   @map("xero_tenant_id")
  accessTokenEnc  String   @map("access_token_enc")
  refreshTokenEnc String   @map("refresh_token_enc")
  expiresAt       DateTime @map("expires_at")
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("xero_connections")
}
